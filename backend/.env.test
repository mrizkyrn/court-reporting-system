# ==================== Test Environment Configuration ====================
# This file contains environment variables for running tests
# Safe to commit to version control (no real secrets)

# ==================== Application Configuration ====================
NODE_ENV=test
PORT=8000

# ==================== Database Configuration ====================
# Test database - separate from development to avoid data conflicts
DATABASE_URL="postgresql://test:test@localhost:5432/authapi_test?schema=public"
DIRECT_URL="postgresql://test:test@localhost:5432/authapi_test?schema=public"

# ==================== Authentication & Security ====================
# Test JWT secrets (at least 32 characters each)
JWT_ACCESS_SECRET=test-access-secret-must-be-at-least-32-characters-long-for-security
JWT_REFRESH_SECRET=test-refresh-secret-must-be-at-least-32-characters-long-for-security

# JWT Token Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ==================== CORS & Frontend Configuration ====================
FRONTEND_URL=http://localhost:3000
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ==================== Email Service (Resend) ====================
# Test API key (mock in tests)
RESEND_API_KEY=test-resend-api-key-for-testing-only
EMAIL_FROM=test@example.com

# ==================== File Storage (Cloudinary) ====================
# Test credentials (mocked in tests)
CLOUDINARY_CLOUD_NAME=test_cloud_name
CLOUDINARY_API_KEY=test_api_key
CLOUDINARY_API_SECRET=test_api_secret

# ==================== Payment Gateway (Midtrans) ====================
# Test credentials (mocked in tests)
MIDTRANS_SERVER_KEY=test_midtrans_server_key
MIDTRANS_CLIENT_KEY=test_midtrans_client_key
MIDTRANS_NOTIFICATION_URL=http://localhost:8000/api/payments/midtrans/notification

# ==================== Database Seeding ====================
# Test admin credentials (not used in unit tests)
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=test-admin-password-123
ADMIN_NAME=Test Admin
