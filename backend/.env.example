# ==================== Application Configuration ====================
# Environment: development | staging | production
NODE_ENV=development

# Server port
PORT=8000

# ==================== Database Configuration ====================
# PostgreSQL connection strings
# For local development: postgresql://user:password@localhost:5432/dbname
# For Supabase: Use connection pooler URL for DATABASE_URL and direct URL for DIRECT_URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/authapi?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/authapi?schema=public"

# ==================== CORS & Frontend Configuration ====================
# Frontend application URL (used for email links and CORS)
FRONTEND_URL=http://localhost:3000